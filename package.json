  "bugs": {
    "url": "https://github.com/RoeiMeiri9/ExtendedMD/issues"
  },
  "homepage": "https://github.com/RoeiMeiri9/ExtendedMD#readme",
  "devDependencies": {
    "@babel/code-frame": "^7.29.0",
    "@types/babel__code-frame": "^7.27.0",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
