{
  "name": "extendedmd",
  "version": "1.0.0",
  "description": "**ExtendedMD (EMD)** is a powerful enhancement of the standard Markdown syntax, designed to bridge the gap between static text and dynamic content.",
  "scripts": {
    "build": "tsc -b",
    "watch": "tsc -b --watch",
    "barrel": "node --import tsx/esm scripts/generate-barrel.ts"
  },
